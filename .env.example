# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional legacy alias (server helpers accept either)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Minimum market cap for token qualification (USD)
NEXT_PUBLIC_MIN_MARKET_CAP=10000

# DexScreener social update cost (USD)
NEXT_PUBLIC_DEXSCREENER_UPDATE_COST=299

# Pump.fun creator vault (on-chain fees balance — read via Solana RPC, no Pump SDK)
CREATOR_PUBLIC_KEY=your-token-creator-wallet-pubkey
# Optional alias for CREATOR_PUBLIC_KEY
# WATCH_ACCOUNT=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
CREATOR_VAULT_CACHE_MS=4000
NEXT_PUBLIC_CREATOR_VAULT_POLL_MS=5000
